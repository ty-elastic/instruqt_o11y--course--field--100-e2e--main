            "max": {
              "field": "@timestamp"
            }
          },
          "customer_id": {
            "terms": {
              "field": "customer_id",
              "size": 15
            },
            "aggregations": {
              "shares_traded_per_customer_histogram": {
                "max": {
                  "field": "shares_traded_per_customer_histogram"
                }
              }
            }
          }
        }
      }
    },
    "frequency": "60s",
    "indices": [
      "metrics-trader"
    ],
    "scroll_size": 1000,
    "delayed_data_check_config": {
      "enabled": true
    }
  },
  "description": "",
  "analysis_config": {
    "summary_count_field_name": "doc_count",
    "bucket_span": "1m",
    "detectors": [
      {
        "detector_description": "max(\"shares_traded_per_customer_histogram\") over \"customer_id\"",
        "function": "max",
        "field_name": "shares_traded_per_customer_histogram",
        "over_field_name": "customer_id",
        "detector_index": 0
      }
    ],
    "influencers": [
