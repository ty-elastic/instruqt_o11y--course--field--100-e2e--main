{
      "job_id": "postgresql_query_anomalies",
      "datafeed_config": {
        "datafeed_id": "datafeed-postgresql_query_anomalies",
        "job_id": "postgresql_query_anomalies",
        "query_delay": "30s",
        "chunking_config": {
          "mode": "auto"
        },
        "indices_options": {
          "ignore_unavailable": false,
          "expand_wildcards": [
            "open"
          ],
          "allow_no_indices": true,
          "ignore_throttled": true
        },
        "query": {
          "bool": {
            "must": [
              {
                "exists": {
                  "field": "attributes.postgresql.total_exec_time"
                }
              }
            ]
          }
        },
        "frequency": "60s",
        "indices": [
          "logs-postgresqlreceiver.otel-*"
        ],
        "scroll_size": 1000,
        "delayed_data_check_config": {
          "enabled": true
        }
      },
      "description": "",
      "analysis_config": {
        "bucket_span": "1m",
        "detectors": [
          {
            "detector_description": "max(\"attributes.postgresql.total_exec_time\") partitionfield=\"service.instance.id\"",
            "function": "max",
            "field_name": "attributes.postgresql.total_exec_time",
            "partition_field_name": "service.instance.id",
            "detector_index": 0
          },
          {
            "detector_description": "max(\"attributes.postgresql.calls\") partitionfield=\"service.instance.id\"",
            "function": "max",
            "field_name": "attributes.postgresql.calls",
            "partition_field_name": "service.instance.id",
            "detector_index": 1
          },
          {
            "detector_description": "max(\"attributes.postgresql.rows\") partitionfield=\"service.instance.id\"",
            "function": "max",
            "field_name": "attributes.postgresql.rows",
            "partition_field_name": "service.instance.id",
            "detector_index": 2
          }
        ],
        "influencers": [
          "attributes.db.namespace",
          "attributes.db.query.text"
        ],
        "model_prune_window": "30d"
      },
      "analysis_limits": {
        "model_memory_limit": "11mb",
        "categorization_examples_limit": 4
      },
      "data_description": {
        "time_field": "@timestamp",
        "time_format": "epoch_ms"
      },
      "model_plot_config": {
        "enabled": false,
        "annotations_enabled": false
      },
      "model_snapshot_retention_days": 10,
      "daily_model_snapshot_retention_after_days": 1,
      "results_index_name": "shared",
      "allow_lazy_open": false
    }