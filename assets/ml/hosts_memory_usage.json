{
  "job_id": "hosts_memory_usage",
  "datafeed_config": {
    "datafeed_id": "datafeed-hosts_memory_usage",
    "job_id": "hosts_memory_usage",
    "query_delay": "64000ms",
    "chunking_config": {
      "mode": "auto"
    },
    "indices_options": {
      "ignore_unavailable": false,
      "expand_wildcards": [
        "open"
      ],
      "allow_no_indices": true,
      "ignore_throttled": true
    },
    "query": {
      "bool": {
        "must": [
          {
            "exists": {
              "field": "system.memory"
            }
          }
        ],
        "filter": [
          {
            "bool": {
              "must": [],
              "filter": [],
              "should": [],
              "must_not": []
            }
          },
          {
            "bool": {
              "should": [
                {
                  "term": {
                    "event.module": "system"
                  }
                },
                {
                  "term": {
                    "metricset.module": "system"
                  }
                }
              ],
              "minimum_should_match": 1
            }
          }
        ]
      }
    },
    "indices": [
      "metrics-*",
      "metricbeat-*"
    ],
    "scroll_size": 1000,
    "delayed_data_check_config": {
      "enabled": true
    }
  },
  "groups": [
    "hosts",
    "metrics"
  ],
  "description": "Metrics: Hosts - Identify unusual spikes in memory usage across hosts.",
  "analysis_config": {
    "bucket_span": "15m",
    "detectors": [
      {
        "detector_description": "max('system.memory.actual.used.pct')",
        "function": "max",
        "field_name": "system.memory.actual.used.pct",
        "custom_rules": [
          {
            "actions": [
              "skip_result"
            ],
            "conditions": [
              {
                "applies_to": "actual",
                "operator": "lt",
                "value": 0.1
              }
            ]
          }
        ],
        "detector_index": 0
      }
    ],
    "influencers": [
      "host.name"
    ],
    "model_prune_window": "30d"
  },
  "analysis_limits": {
    "model_memory_limit": "64mb",
    "categorization_examples_limit": 4
  },
  "data_description": {
    "time_field": "@timestamp",
    "time_format": "epoch_ms"
  },
  "model_snapshot_retention_days": 10,
  "daily_model_snapshot_retention_after_days": 1,
  "results_index_name": "shared",
  "allow_lazy_open": false,
  "custom_settings": {
    "custom_urls": [
      {
        "url_name": "Host Metrics",
        "url_value": "metrics/detail/host/$host.name$?_a=(autoReload:!f,refreshInterval:5000,time:(from:%27$earliest$%27,interval:%3E%3D1m,to:%27$latest$%27))"
      }
    ],
    "metrics_source_config": {
      "indexPattern": "metrics-*,metricbeat-*",
      "timestampField": "@timestamp",
      "bucketSpan": 900000
    }
  }
}