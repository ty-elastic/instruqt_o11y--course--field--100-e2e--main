#!/bin/bash
WORKING_DIR=/workspace/workshop

#set -euxo pipefail
set +x

wait_for_instruqt_bootstrap() {
    # Wait for the Instruqt host bootstrap to finish
    until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]
    do
        sleep 1
    done
}

wait_for_kubernetes_api() {
    # Wait for the Kubernetes API server to become available
    while ! curl --silent --fail --output /dev/null http://localhost:8001/api
    do
        sleep 1
    done
}

setup_bash_shell() {
    # Enable bash completion for kubectl
    echo "source /usr/share/bash-completion/bash_completion" >> /root/.bashrc
    echo "complete -F __start_kubectl k" >> /root/.bashrc
}

# Wait for the Instruqt host bootstrap to finish
wait_for_instruqt_bootstrap

# Set up bash shell
setup_bash_shell

# Wait for the Kubernetes API server to become available
wait_for_kubernetes_api

# ----------------------------------------- CLONE CODE

export COURSE={{COURSE}}
export ARTIFACTS_REPO=elastic-sa/locations/us-central1/repositories/tbekiares-instruqt
export ARTIFACT_VERSION=1.0

mkdir -p $WORKING_DIR
cd $WORKING_DIR

curl -X GET \
     -o $COURSE.tgz \
     "https://artifactregistry.googleapis.com/download/v1/projects/$ARTIFACTS_REPO/files/$COURSE%3A$ARTIFACT_VERSION%3A$COURSE.tgz:download?alt=media"
tar -xzf $COURSE.tgz

# ----------------------------------------- APPS

source $WORKING_DIR/instruqt/scripts/vars.sh -w true

# services
$WORKING_DIR/build.sh -z $WORKING_DIR -o serverless -c $COURSE -d true -n true -b false -s all -j $ELASTICSEARCH_URL -h $KIBANA_URL -i $ELASTICSEARCH_APIKEY -k $INGEST_URL:443

# synthetics, profiling
$WORKING_DIR/build.sh -z $WORKING_DIR -o false -c $COURSE -d false -b false -s none -j $ELASTICSEARCH_URL -h $KIBANA_URL -i $ELASTICSEARCH_APIKEY -k $INGEST_URL:443 -p true -m true

# assets
$WORKING_DIR/build.sh -z $WORKING_DIR -o false -c $COURSE -d false -b false -s none -j $ELASTICSEARCH_URL -h $KIBANA_URL -i $ELASTICSEARCH_APIKEY -k $INGEST_URL:443 -w true -e http://$HOSTNAME.$_SANDBOX_ID.instruqt.io:43210

# grafana
$WORKING_DIR/build.sh -z $WORKING_DIR -o false -c $COURSE -d false -b false -s none -j $ELASTICSEARCH_URL -h $KIBANA_URL -i $ELASTICSEARCH_APIKEY -k $INGEST_URL:443 -g true

# ramen
$WORKING_DIR/assets/scripts/ramen.sh -z $WORKING_DIR -h $KIBANA_URL -i $ELASTICSEARCH_APIKEY -j $ELASTICSEARCH_URL
